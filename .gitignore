# Dependencies
node_modules/
frontend/node_modules/
venv/
.venv/
__pycache__/
*.pyc
.pytest_cache/
.next/
out/

# Env and secrets
.env
.env.local
*.pem

# DB (optional local SQLite etc.)
*.db
embeddings/vectors.db

# Uploads (optional: ignore binary content)
documents/
documents/pdfs/*
documents/notes/*
documents/slides/*
!documents/pdfs/.gitkeep
!documents/notes/.gitkeep
!documents/slides/.gitkeep

# IDE and OS
.idea/
.vscode/
.DS_Store
*.log

# TypeScript incremental build cache
*.tsbuildinfo

# Per-user RAG storage (created when users upload; never commit real data)
backend/documents/*
!backend/documents/.gitkeep
